{
  "IsEncrypted": false,
  "Values": {
    "AzureWebJobsStorage": "<connection-string-do-storage-account>",
    "FUNCTIONS_WORKER_RUNTIME": "python",

    "AZURE_OPENAI_ENDPOINT": "https://<seu-recurso>.openai.azure.com/",
    "AZURE_OPENAI_KEY": "<sua-api-key>",
    "AZURE_OPENAI_CHAT_DEPLOYMENT": "gpt-4o",
    "AZURE_OPENAI_EMBEDDING_DEPLOYMENT": "text-embedding-3-small",

    "AZURE_SEARCH_ENDPOINT": "https://<seu-recurso>.search.windows.net",
    "AZURE_SEARCH_KEY": "<sua-admin-key>",
    "AZURE_SEARCH_INDEX_NAME": "tea-conhecimento",

    "CHUNK_SIZE": "800",
    "CHUNK_OVERLAP": "100",
    "RAG_TOP_N": "5"
  }
}